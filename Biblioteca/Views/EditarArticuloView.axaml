<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Biblioteca.Views.EditarArticuloView"
    Title="Nuevo Artículo"
    Width="500" Height="650"
    HorizontalAlignment="Center"
    VerticalAlignment="Center"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:vm="clr-namespace:Biblioteca.ViewModels"
    d:DataContext="{d:DesignInstance vm:EditarArticuloViewModel, IsDesignTimeCreatable=True}"
    x:DataType="vm:EditarArticuloViewModel">

    <StackPanel Margin="10" Spacing="10">

        <TextBlock Text="Tipo:" />
        <ComboBox ItemsSource="{Binding Tipos}"
                  SelectedItem="{Binding TipoSeleccionado}" />

        <TextBlock Text="Título:" />
        <TextBox Text="{Binding Titulo}" />

        <TextBlock Text="Año:" />
        <TextBox Text="{Binding Año}" MaxLength="4"/>

        <!-- Campos específicos según tipo -->
        <StackPanel>
            <StackPanel IsVisible="{Binding EsLibro}">
                <TextBlock Text="ISBN-10:" />
                <TextBox Text="{Binding Isbn10}" MaxLength="10" />
            </StackPanel>

            <StackPanel IsVisible="{Binding EsAudiolibro}">
                <TextBlock Text="Fecha inicio:" />
                <DatePicker SelectedDate="{Binding FechaInicio}" />

                <TextBlock Text="Fecha fin:" />
                <DatePicker SelectedDate="{Binding FechaFin}" />
            </StackPanel>
        </StackPanel>

        <Button Content="Guardar"
                Command="{Binding GuardarCommand}"
                Margin="0,10,0,0" />

    </StackPanel>
</Window>